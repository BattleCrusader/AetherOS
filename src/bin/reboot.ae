# Aether OS — reboot command
# Standalone binary: reboots the system via keyboard controller

import "../lib/libaether.ae"

func main(): u64 {
    puts("Rebooting...\n")
    asm {
        mov al, 0xFE
        out 0x64, al
    }
    asm {
        cli
    .loop:
        hlt
        jmp .loop
    }
    return 0
}
